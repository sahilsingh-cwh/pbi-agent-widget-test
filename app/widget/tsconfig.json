{
  "compilerOptions": {
    "allowJs": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./.tmp/build",
    "moduleResolution": "node",
    "declaration": true,
    "lib": ["es2022", "dom"],
    "jsx": "react",
    "module": "commonjs",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "files": ["./src/visual.tsx"],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
